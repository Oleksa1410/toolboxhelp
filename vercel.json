{
  "trailingSlash": false,

  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/img/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/VERSION",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],

  "redirects": [
    { "source": "/about.html",    "destination": "/about",    "permanent": true },
    { "source": "/contacts.html", "destination": "/contacts", "permanent": true },
    { "source": "/privacy.html",  "destination": "/privacy",  "permanent": true }
  ],

  "rewrites": [
    { "source": "/about",     "destination": "/pages/about.html" },
    { "source": "/contacts",  "destination": "/pages/contacts.html" },
    { "source": "/privacy",   "destination": "/pages/privacy.html" },

    { "source": "/aspect",    "destination": "/index.html" },
    { "source": "/units",     "destination": "/index.html" },
    { "source": "/color",     "destination": "/index.html" },
    { "source": "/password",  "destination": "/index.html" },
    { "source": "/textcount", "destination": "/index.html" },
    { "source": "/qrbar",     "destination": "/index.html" },
    { "source": "/hash",      "destination": "/index.html" },
    { "source": "/json",      "destination": "/index.html" },
    { "source": "/base64",    "destination": "/index.html" },
    { "source": "/diff",      "destination": "/index.html" },
    { "source": "/urlencode", "destination": "/index.html" },
    { "source": "/dummydata", "destination": "/index.html" },
    { "source": "/markdown",  "destination": "/index.html" },
    { "source": "/whois",     "destination": "/index.html" },
    { "source": "/ascii",     "destination": "/index.html" },
    { "source": "/favicon",    "destination": "/index.html" },
    { "source": "/base64img",  "destination": "/index.html" },
    { "source": "/clipformat",  "destination": "/index.html" },
    { "source": "/diffviewer",  "destination": "/index.html" },
    { "source": "/jwt",         "destination": "/index.html" },
    { "source": "/linesort",    "destination": "/index.html" },
    { "source": "/regexcheck",  "destination": "/index.html" },
    { "source": "/admin",       "destination": "/index.html" }
  ]
}